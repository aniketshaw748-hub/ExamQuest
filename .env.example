# Copy to .env and fill in. All keys are optional; the app runs without them.

# AI tutor (server-side, never shipped to the browser). Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Where the tutor's bug/feature reports are delivered (optional). Set ONE:
#   a Discord/Slack/Formspree/Zapier/generic JSON webhook...
REPORT_WEBHOOK_URL=
#   ...or a GitHub token + repo ("owner/name") to open an issue per report.
#   Token needs issue-write: fine-grained PAT with "Issues: Read and write" on the repo,
#   or a classic PAT with "public_repo" (public) / "repo" (private) scope.
GITHUB_TOKEN=
GITHUB_REPO=owner/name

# PostHog product analytics (optional). Inert until the key is set; the library is
# loaded only when a key exists. Project key from your PostHog project settings.
VITE_PUBLIC_POSTHOG_KEY=
# Optional. Defaults to US cloud. Use https://eu.i.posthog.com for the EU region.
VITE_PUBLIC_POSTHOG_HOST=
